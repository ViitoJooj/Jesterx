# postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jesterx
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_SSL=disable

# jwt
JWT_ACCESS_TOKEN=teste
JWT_REFRESH_TOKEN=teste1

# environment
# dev or prod
ENVIRONMENT=dev

# resend
RESEND_KEY=

# stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# storage local — pasta onde os arquivos enviados serão salvos
# Subpastas: images/, videos/, docs/
STORAGE_PATH=./data

# frontend
FRONTEND_URL=
BACKEND_URL=http://localhost:5173

# stripe webhook (optional — leave empty to skip signature validation in dev)
STRIPE_WEBHOOK_SECRET=

# platform commission percentage (optional — defaults to 5%)
PLATFORM_COMMISSION_PCT=5

# frontend (vite) — VITE_* são expostos no bundle JS
VITE_WEBSITE_ID=
VITE_API_URL=http://localhost:8080
