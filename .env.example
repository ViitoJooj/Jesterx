# postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jesterx
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_SSL=disable

# jwt
JWT_ACCESS_TOKEN=teste
JWT_REFRESH_TOKEN=teste1

# environment
# dev or prod
ENVIRONMENT=dev

# resend
RESEND_KEY=

# stripe
STRIPE_PUBLIC_KEY=
