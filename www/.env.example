# ============================================================
# Variáveis de ambiente do frontend (Vite)
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NÃO é commitado (ver .gitignore raiz).
# ============================================================

# ID do website raiz da plataforma (gerado pelo banco ao criar o site principal)
VITE_WEBSITE_ID=

# URL do projeto Supabase
# Encontre em: https://supabase.com/dashboard → seu projeto → Settings → API → Project URL
VITE_SUPABASE_URL=

# Chave ANON pública do Supabase (segura para o browser)
# ⚠️  Use SOMENTE a "anon / public key", NUNCA a "service_role key"
# Encontre em: https://supabase.com/dashboard → seu projeto → Settings → API → Project API Keys
VITE_SUPABASE_ANON_KEY=

# ============================================================
# SEGURANÇA — leia antes de publicar em produção
# ============================================================
# 1. Variáveis VITE_* ficam embutidas no bundle JS (visíveis no browser).
#    Isso é ESPERADO para a anon key do Supabase — ela é pública por design.
#
# 2. A proteção real dos arquivos é feita pelas políticas RLS (Row Level Security)
#    no bucket "img" do Supabase Storage:
#      - INSERT: autenticado via JWT ou policy de "anon pode fazer upload"
#      - SELECT: público (para exibir imagens)
#      - DELETE/UPDATE: somente o dono do arquivo
#
# 3. A service_role key (admin) fica SOMENTE no .env do backend Go,
#    nunca neste arquivo.
# ============================================================
